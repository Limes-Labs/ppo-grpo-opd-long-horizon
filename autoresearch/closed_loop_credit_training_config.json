{
  "name": "closed-loop-coverage-gated-credit",
  "command": [
    "python3",
    "-m",
    "experiments.closed_loop_credit_training",
    "--critic-replay-limit",
    "80",
    "--gate-min-count",
    "4",
    "--train-iterations",
    "50",
    "--groups-per-iteration",
    "16",
    "--group-size",
    "5",
    "--max-steps",
    "14",
    "--eval-groups",
    "60",
    "--output-json",
    "autoresearch/runs/closed_loop_credit_training_low_coverage.json",
    "--output-md",
    "autoresearch/runs/closed_loop_credit_training_low_coverage.md"
  ],
  "metric_keys": [
    "coverage_minus_group_return",
    "coverage_minus_group_success",
    "best_is_coverage_gated"
  ],
  "timeout_seconds": 120
}
